# ── NWEPP Production Environment ──
# Copy this file to .env on the server and fill in the values

# System IP
# Gantinya dengan IP Sumopod Anda, contoh: http://103.x.x.x
PUBLIC_APP_URL=http://YOUR_SUMOPOD_IP:3000
NEXT_PUBLIC_API_URL=http://YOUR_SUMOPOD_IP:8081/api/v1

# Database
DB_USER=nwepp
DB_PASSWORD=nwepp_secret_CHANGE_ME
DB_NAME=nwepp_db
DB_HOST=postgres
DB_PORT=5432
DB_SSLMODE=disable

# Server API
SERVER_PORT=8081
SERVER_HOST=0.0.0.0

# JWT (generate a 32+ char random string for production)
JWT_SECRET=CHANGE_ME_TO_A_SECURE_RANDOM_STRING
JWT_ACCESS_TTL_MIN=60
JWT_REFRESH_TTL_DAYS=30

# CORS — comma-separated allowed origins
CORS_ORIGINS=http://YOUR_SUMOPOD_IP:3000
